# FastAPI secret key for session signing — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string

# Supabase Postgres connection string
# Found in Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Format: postgresql://postgres:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres

# Supabase project URL and anon/service_role key
# Found in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Gmail SMTP credentials for password reset emails
# If these are not set, reset codes print to the console (dev mode)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password
